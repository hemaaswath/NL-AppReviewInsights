# OpenAI / Groq API Configuration
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Phase 2 — Groq rate-limit aware (see Docs/implementationplan.md)
PHASE2_MAX_REVIEWS=1000
PHASE2_THEME_SAMPLE_SIZE=200
PHASE2_QUOTE_SAMPLE_SIZE=30
PHASE2_LLM_SENTIMENT_MAX=150
PHASE2_SENTIMENT_BATCH_SIZE=20

# App Store Configuration
GOOGLE_PLAY_PACKAGE_NAME=com.groww
APPLE_APP_STORE_ID=your_apple_app_id_here

# Database Configuration
DATABASE_PATH=data/reviews.db

# Google Cloud OAuth project: Appreview (credentials.json + token.json in MCPServer/saksham-mcp-server)
# saksham-mcp-server (Docs + Gmail on one port)
# https://github.com/saksham20189575/saksham-mcp-server
MCP_SERVER_URL=http://127.0.0.1:8000
GOOGLE_DOCS_MCP_SERVER_URL=http://127.0.0.1:8000
GMAIL_MCP_SERVER_URL=http://127.0.0.1:8000

# Existing Google Doc to append weekly reports (from document URL)
GOOGLE_DOC_ID=your_google_doc_id_here

# Email Configuration
EMAIL_RECIPIENT=your.email@example.com

# Optional: skip terminal approval prompts on the MCP server (set same var when starting uvicorn)
# AUTO_APPROVE=true

# Optional: local .eml files when MCP is down (Phase 4 will still fail without a real draft_id)
# GMAIL_ALLOW_LOCAL_FALLBACK=false
