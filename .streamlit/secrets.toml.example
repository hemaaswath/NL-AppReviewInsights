# Copy to secrets.toml for local Streamlit (never commit secrets.toml).
# On Streamlit Cloud: paste the same keys in App settings → Secrets.

GROQ_API_KEY = "your_groq_key"
GOOGLE_PLAY_PACKAGE_NAME = "com.nextbillion.groww"
GOOGLE_DOC_ID = "your_google_doc_id"
EMAIL_RECIPIENT = "you@gmail.com"
# Optional — on Streamlit Cloud leave unset (uses /tmp/groww_reviews.db automatically)
# DATABASE_PATH = "data/reviews.db"

# One-line JSON from token.json (run scripts/export_streamlit_secrets.ps1)
GOOGLE_TOKEN_JSON = '{"token": "...", "refresh_token": "...", ...}'

# Optional: full credentials.json as one line (usually not required if token is set)
# GOOGLE_CREDENTIALS_JSON = '{"installed":{...}}'
