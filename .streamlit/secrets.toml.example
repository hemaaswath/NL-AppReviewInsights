# Copy to secrets.toml for local Streamlit (never commit secrets.toml).
# On Streamlit Cloud: paste keys in App settings → Secrets ONLY (not GitHub).

GROQ_API_KEY = "your_groq_key"
GOOGLE_PLAY_PACKAGE_NAME = "com.nextbillion.groww"
GOOGLE_DOC_ID = "your_google_doc_id"
EMAIL_RECIPIENT = "you@gmail.com"

# Run locally: .\scripts\export_streamlit_secrets.ps1
# Then paste the GOOGLE_TOKEN_JSON line from .streamlit/secrets_export.txt here.
# GOOGLE_TOKEN_JSON = "PASTE_ONE_LINE_JSON_FROM_export_script"
