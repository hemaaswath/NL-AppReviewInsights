#!/bin/sh
# Block commits that include secret files or secret content.
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 1

_run() {
  if command -v python >/dev/null 2>&1; then
    python "$ROOT/scripts/$1" || exit 1
  elif command -v py >/dev/null 2>&1; then
    py "$ROOT/scripts/$1" || exit 1
  else
    echo "Install Python for secret checks."
    exit 1
  fi
}

_run purge_repo_secrets.py
_run secret_scan.py staged
_run repo_git_guard.py

exit 0
