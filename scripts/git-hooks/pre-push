#!/bin/sh
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 1

_run() {
  if command -v python >/dev/null 2>&1; then
    python "$ROOT/scripts/$1" || exit 1
  elif command -v py >/dev/null 2>&1; then
    py "$ROOT/scripts/$1" || exit 1
  else
    echo "pre-push: install Python"
    exit 1
  fi
}

_run purge_repo_secrets.py
_run secret_scan.py push
_run secret_scan.py tracked
_run repo_git_guard.py

exit 0
